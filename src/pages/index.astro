---
import Layout from '../layouts/Layout.astro';
import { Calculator } from '../components/Calculator';
---

<Layout title="物理实验数据分析辅助工具">
  <main>
    <Calculator client:load />
  </main>
</Layout>

<style>
  main {
    min-height: 100vh;
    padding: 1rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  @media (max-width: 768px) {
    main {
      padding: 0.5rem;
    }
  }
</style>